# ============================================================
#  tool_facebook - ví dụ cấu hình biến môi trường (.env)
#  Copy file này thành `.env` rồi chỉnh theo nhu cầu của bạn.
#  Định dạng: KEY=VALUE (mỗi dòng 1 cặp). Comment bắt đầu bằng #.
#  Hỗ trợ quoted value: KEY="giá trị có space"
# ============================================================

# ---- Server ----
# Địa chỉ lắng nghe, ví dụ ":8787", "0.0.0.0:8080"
LISTEN=:8787

# Timeout mỗi HTTP request (giây)
TIMEOUT=25

# Số lần retry khi request thất bại
RETRIES=2

# ---- Facebook cookie ----
# Chuỗi cookie đầy đủ để gọi graph.facebook.com (datr, sb, ps_l, ps_n, wd, ...)
# Lấy bằng cách đăng nhập Facebook rồi copy từ DevTools > Application > Cookies
FB_COOKIE=datr=xxx; sb=xxx; ps_l=1; ps_n=1; wd=612x945

# ---- Proxy (m2proxy hoặc proxy tương đương) ----
# Bật/tắt sử dụng proxy. true / 1 / yes / on => bật
USE_PROXY=false

# Nếu proxy lỗi có fallback về direct (không qua proxy) hay không
PROXY_FALLBACK_DIRECT=true

# Host:port của proxy server, ví dụ "gate.m2proxy.io:8080"
PROXY_HOST=

# User:pass của proxy. Với m2proxy có thể kèm session-XXX để giữ IP cố định
# Ví dụ: myuser:mypass-session-abc123
PROXY_USER=

# Số session proxy xoay vòng (chỉ áp dụng khi PROXY_USER không truyền session cố định)
PROXY_POOL=200
